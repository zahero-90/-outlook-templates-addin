<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:requirements="http://schemas.microsoft.com/office/2012/01/officerequirements"
  xsi:type="MailApp">

  <!-- ══════════════════════════════════════════════════════════════
       MY EMAIL TEMPLATES — Outlook Web Add-in Manifest
       ══════════════════════════════════════════════════════════════
       BEFORE DEPLOYING: Replace every instance of
         https://priorityworldwide.sharepoint.com/sites/InformationTechnolgy/Shared%20Documents/Forms/AllItems.aspx?id=%2Fsites%2FInformationTechnolgy%2FShared%20Documents%2FOutlook%20Template%20add%2Din%20%2D%20DO%20NOT%20DELETE&viewid=12e66a96%2Dcca0%2D4976%2D8eaa%2D0703670af3de
       with your actual hosting URL (GitHub Pages, Azure, SharePoint)
       See README.html for full hosting and deployment instructions.
       ══════════════════════════════════════════════════════════════ -->

  <!-- Unique ID — do NOT change this after deployment -->
  <Id>d4c3b2a1-e6f5-4321-9876-abcdef012345</Id>
  <Version>1.0.0</Version>
  <ProviderName>Priority Worldwide IT</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>

  <DisplayName DefaultValue="My Email Templates" />
  <Description DefaultValue="Save and instantly insert unlimited email templates into any email. Your signature is automatically preserved. Unlimited templates, stored per user." />

  <!-- Replace with your actual hosted icon URLs -->
  <IconUrl DefaultValue="https://priorityworldwide.sharepoint.com/sites/InformationTechnolgy/Shared%20Documents/Forms/AllItems.aspx?id=%2Fsites%2FInformationTechnolgy%2FShared%20Documents%2FOutlook%20Template%20add%2Din%20%2D%20DO%20NOT%20DELETE&viewid=12e66a96%2Dcca0%2D4976%2D8eaa%2D0703670af3de/assets/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="https://priorityworldwide.sharepoint.com/sites/InformationTechnolgy/Shared%20Documents/Forms/AllItems.aspx?id=%2Fsites%2FInformationTechnolgy%2FShared%20Documents%2FOutlook%20Template%20add%2Din%20%2D%20DO%20NOT%20DELETE&viewid=12e66a96%2Dcca0%2D4976%2D8eaa%2D0703670af3de/assets/icon-64.png" />
  <SupportUrl DefaultValue="https://priorityworldwide.sharepoint.com/sites/InformationTechnolgy/Shared%20Documents/Forms/AllItems.aspx?id=%2Fsites%2FInformationTechnolgy%2FShared%20Documents%2FOutlook%20Template%20add%2Din%20%2D%20DO%20NOT%20DELETE&viewid=12e66a96%2Dcca0%2D4976%2D8eaa%2D0703670af3de/" />

  <AppDomains>
    <!-- Add your hosting domain here -->
    <AppDomain>https://YOUR-DOMAIN.com</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>

  <Requirements>
    <Sets>
      <!-- Requires Mailbox 1.3+ for prependAsync (insert above signature) -->
      <Set Name="Mailbox" MinVersion="1.3" />
    </Sets>
  </Requirements>

  <!-- Legacy form factor — shows add-in in compose window -->
  <FormSettings>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://priorityworldwide.sharepoint.com/sites/InformationTechnolgy/Shared%20Documents/Forms/AllItems.aspx?id=%2Fsites%2FInformationTechnolgy%2FShared%20Documents%2FOutlook%20Template%20add%2Din%20%2D%20DO%20NOT%20DELETE&viewid=12e66a96%2Dcca0%2D4976%2D8eaa%2D0703670af3de/src/taskpane.html" />
        <RequestedHeight>600</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <!-- ReadWriteItem needed to insert into email body -->
  <Permissions>ReadWriteItem</Permissions>

  <!-- Show add-in button when composing or replying to messages -->
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit" />
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <!-- ══════════════════════════════════════════════════════════════
       VERSION OVERRIDES — Defines the Ribbon button and task pane
       This is what creates the button in the compose toolbar
       ══════════════════════════════════════════════════════════════ -->
  <VersionOverrides
    xmlns="http://schemas.microsoft.com/office/mailappversionoverrides"
    xsi:type="VersionOverridesV1_0">

    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox" />
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>

          <!-- Function file — handles background ribbon commands -->
          <FunctionFile resid="Commands.Url" />

          <!-- ── Message Compose: New Email ── -->
          <ExtensionPoint xsi:type="MessageComposeCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="composeTemplatesGroup">
                <Label resid="GroupLabel" />

                <!-- Main Ribbon Button -->
                <Control xsi:type="Button" id="composeOpenTemplatesPane">
                  <Label resid="TaskpaneButton.Label" />
                  <Supertip>
                    <Title resid="TaskpaneButton.Label" />
                    <Description resid="TaskpaneButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16" />
                    <bt:Image size="32" resid="Icon.32x32" />
                    <bt:Image size="80" resid="Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="Taskpane.Url" />
                    <!-- Pin the taskpane open by default -->
                    <SupportsPinning>true</SupportsPinning>
                  </Action>
                </Control>

              </Group>
            </OfficeTab>
          </ExtensionPoint>

          <!-- ── Message Reply / ReplyAll / Forward ── -->
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="readTemplatesGroup">
                <Label resid="GroupLabel" />
                <Control xsi:type="Button" id="readOpenTemplatesPane">
                  <Label resid="TaskpaneButton.Label" />
                  <Supertip>
                    <Title resid="TaskpaneButton.Label" />
                    <Description resid="TaskpaneButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16" />
                    <bt:Image size="32" resid="Icon.32x32" />
                    <bt:Image size="80" resid="Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="Taskpane.Url" />
                    <SupportsPinning>true</SupportsPinning>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>

        </DesktopFormFactor>
      </Host>
    </Hosts>

    <!-- ── Resource Definitions ── -->
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://priorityworldwide.sharepoint.com/sites/InformationTechnolgy/Shared%20Documents/Forms/AllItems.aspx?id=%2Fsites%2FInformationTechnolgy%2FShared%20Documents%2FOutlook%20Template%20add%2Din%20%2D%20DO%20NOT%20DELETE&viewid=12e66a96%2Dcca0%2D4976%2D8eaa%2D0703670af3de/assets/icon-16.png" />
        <bt:Image id="Icon.32x32" DefaultValue="https://priorityworldwide.sharepoint.com/sites/InformationTechnolgy/Shared%20Documents/Forms/AllItems.aspx?id=%2Fsites%2FInformationTechnolgy%2FShared%20Documents%2FOutlook%20Template%20add%2Din%20%2D%20DO%20NOT%20DELETE&viewid=12e66a96%2Dcca0%2D4976%2D8eaa%2D0703670af3de/assets/icon-32.png" />
        <bt:Image id="Icon.80x80" DefaultValue="https://priorityworldwide.sharepoint.com/sites/InformationTechnolgy/Shared%20Documents/Forms/AllItems.aspx?id=%2Fsites%2FInformationTechnolgy%2FShared%20Documents%2FOutlook%20Template%20add%2Din%20%2D%20DO%20NOT%20DELETE&viewid=12e66a96%2Dcca0%2D4976%2D8eaa%2D0703670af3de/assets/icon-80.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Commands.Url"  DefaultValue="https://priorityworldwide.sharepoint.com/sites/InformationTechnolgy/Shared%20Documents/Forms/AllItems.aspx?id=%2Fsites%2FInformationTechnolgy%2FShared%20Documents%2FOutlook%20Template%20add%2Din%20%2D%20DO%20NOT%20DELETE&viewid=12e66a96%2Dcca0%2D4976%2D8eaa%2D0703670af3de/src/commands.html" />
        <bt:Url id="Taskpane.Url"  DefaultValue="https://priorityworldwide.sharepoint.com/sites/InformationTechnolgy/Shared%20Documents/Forms/AllItems.aspx?id=%2Fsites%2FInformationTechnolgy%2FShared%20Documents%2FOutlook%20Template%20add%2Din%20%2D%20DO%20NOT%20DELETE&viewid=12e66a96%2Dcca0%2D4976%2D8eaa%2D0703670af3de/src/taskpane.html" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel"             DefaultValue="My Templates" />
        <bt:String id="TaskpaneButton.Label"   DefaultValue="My Templates" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="TaskpaneButton.Tooltip"
          DefaultValue="Open My Email Templates to quickly insert saved templates into this email. Your signature is automatically preserved." />
      </bt:LongStrings>
    </Resources>

  </VersionOverrides>
</OfficeApp>
